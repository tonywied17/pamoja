{
  "name": "@zero-edge/core",
  "version": "0.0.0",
  "description": "Node.js bindings for the zero-edge device SDK core.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tonywied17/zero-edge.git"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "name": "zero-edge-core",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-unknown-linux-gnu",
        "aarch64-apple-darwin"
      ]
    }
  },
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "engines": {
    "node": ">= 16"
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "node test.js",
    "prepublishOnly": "napi prepublish -t npm"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4"
  }
}
